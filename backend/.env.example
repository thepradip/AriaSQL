# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Database — any SQLAlchemy-compatible async URL
DATABASE_URL=sqlite+aiosqlite:///./health.db

# Optional: PII columns for SQLAS safety scoring (comma-separated)
# PII_COLUMNS=email,phone,ssn

# Optional: domain hint for better LLM context
# DOMAIN_HINT=This is a healthcare analytics database with patient demographics and activity logs.

# Optional: CORS frontend URL
# FRONTEND_URL=http://localhost:5173

# Large-schema mode (100s of tables)
# BM25+RRF is the default (no extra cost). Add embedding deployment for hybrid search upgrade.
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
# LARGE_SCHEMA_THRESHOLD=20      # tables above this count use semantic retrieval (default: 20)
# MAX_CONTEXT_TABLES=8            # tables retrieved per query before FK expansion (default: 8)
# MAX_COLUMNS_PER_TABLE=30        # columns injected per table (PKs/FKs always included, default: 30)
# SCHEMA_TOKEN_BUDGET=12000       # max tokens injected into schema context (default: 12000)

# Query caching (reduces LLM cost by 60-80% after warm-up)
# CACHE_ENABLED=true
# SEMANTIC_CACHE_THRESHOLD=0.92   # cosine similarity for semantic cache hits (0.88–0.95)
# RESULT_CACHE_TTL=300            # SQL result cache TTL in seconds (0 = disable, 300 = 5min)
